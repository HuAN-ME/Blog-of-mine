# MySQL
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=<your_mysql_password>
MYSQL_DATABASE=blog

# SMTP (optional, for email verification)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=<your_qq_email>
SMTP_PASS=<your_smtp_auth_code>

# Initial admin password (only used on first run)
INIT_ADMIN_PASSWORD=<set_a_strong_password>